# ==============================================================================
# VaultDAO Backend Environment Configuration
# ==============================================================================
# Copy this file to .env and adjust values for your environment.
# The backend validates these variables at startup.

# ------------------------------------------------------------------------------
# 1. Server Configuration
# ------------------------------------------------------------------------------

# HTTP port for the backend server
# Type: number | Default: 8787 | Range: 1-65535
PORT=8787

# Network interface the backend binds to
# Type: string | Default: 0.0.0.0 | Required: Yes
HOST=0.0.0.0

# Runtime mode used for validation and environment behavior
# Type: enum | Default: development | Values: development, test, production
NODE_ENV=development

# Allowed CORS origins (comma-separated list)
# Type: string[] | Default: ["*"] (non-prod), [] (prod) | Required: Yes (production)
# Example: https://app.vaultdao.org,https://api.vaultdao.org
CORS_ORIGIN=*

# Request body size limit (e.g., 10kb, 1mb)
# Type: string | Default: 10kb
REQUEST_BODY_LIMIT=10kb

# API Key for protected endpoints
# Type: string | Required: Yes (production)
API_KEY=

# ------------------------------------------------------------------------------
# 2. Stellar Network & Contract
# ------------------------------------------------------------------------------

# Identifies which Stellar network the backend is targeting
# Type: enum | Default: testnet | Values: testnet, mainnet, futurenet, standalone
STELLAR_NETWORK=testnet

# Soroban RPC base URL for contract and network integrations
# Type: url | Default: https://soroban-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Horizon API base URL for Stellar account and ledger access
# Type: url | Default: https://horizon-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org

# Target VaultDAO contract identifier
# Type: string | Required: Yes | Format: G... or C...
# Production note: The example placeholder below is rejected when NODE_ENV=production.
CONTRACT_ID=CDXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Websocket endpoint for real-time features
# Type: url | Default: ws://localhost:8080 | Protocols: ws, wss
VITE_WS_URL=ws://localhost:8080

# ------------------------------------------------------------------------------
# 3. Event Polling & Background Jobs
# ------------------------------------------------------------------------------

# Enable or disable the asynchronous event polling service
# Type: boolean | Default: true
EVENT_POLLING_ENABLED=true

# Frequency of event polling in milliseconds
# Type: number | Default: 10000 (10 seconds)
EVENT_POLLING_INTERVAL_MS=10000

# Enable or disable the due payments processing job
# Type: boolean | Default: true
DUE_PAYMENTS_JOB_ENABLED=true

# Frequency of due payments job execution in milliseconds
# Type: number | Default: 60000 (1 minute)
DUE_PAYMENTS_JOB_INTERVAL_MS=60000

# Enable or disable the cursor cleanup job
# Type: boolean | Default: true
CURSOR_CLEANUP_JOB_ENABLED=true

# Frequency of cursor cleanup job execution in milliseconds
# Type: number | Default: 86400000 (24 hours)
CURSOR_CLEANUP_JOB_INTERVAL_MS=86400000

# Number of days to retain event cursors before cleanup
# Type: number | Default: 30
CURSOR_RETENTION_DAYS=30

# ------------------------------------------------------------------------------
# 4. Cursor & Database Storage
# ------------------------------------------------------------------------------

# Type of storage adapter for persisting event cursors
# Type: enum | Default: file | Values: file, database
CURSOR_STORAGE_TYPE=file

# Path to the SQLite database file (used if CURSOR_STORAGE_TYPE=database)
# Type: string | Default: ./vaultdao.sqlite
DATABASE_PATH=./vaultdao.sqlite

# ------------------------------------------------------------------------------
# 5. Rate Limiting
# ------------------------------------------------------------------------------

# Toggle Redis-backed rate limiting (falls back to in-memory when false or Redis unavailable)
# Type: boolean | Default: true
RATE_LIMIT_ENABLED=true

# Redis connection string for distributed rate limiting
# Type: url | Optional — omit to use in-memory fallback
# Example: redis://localhost:6379
RATE_LIMIT_REDIS_URL=

# Per-endpoint request limits (requests per minute)
RATE_LIMIT_PROPOSALS_PER_MIN=100
RATE_LIMIT_EXECUTE_PER_MIN=10
RATE_LIMIT_DEFAULT_PER_MIN=60
